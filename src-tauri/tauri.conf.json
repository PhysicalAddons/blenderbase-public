{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Blenderbase",
  "version": "1.1.0",
  "identifier": "com.physicaladdons.blenderbase",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Blenderbase",
        "width": 800,
        "height": 600,
        "decorations": false,
        "label": "main",
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": [
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}